{
  "name": "backend",
  "version": "1.0.0",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "dev": "nodemon --watch src --ext js,mjs,cjs --ignore data/*.json --ignore data/**/*.json src/index.js",
    "start": "npx prisma db push --config=chat.config.ts && node src/index.js",
    "postinstall": "prisma generate && prisma generate --config=chat.config.ts",
    "prisma:generate": "prisma generate && prisma generate --config=chat.config.ts",
    "prisma:migrate": "prisma migrate dev",
    "chat:push": "prisma db push --config=chat.config.ts",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
